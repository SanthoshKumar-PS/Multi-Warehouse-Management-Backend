generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id           Int          @id @default(autoincrement())
  gstin        String
  password     String
  name         String
  sales        String?
  email        String?
  contactNo    String?
  company_name String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime?    @updatedAt
  addresses    Address[]
  SalesOrder   SalesOrder[]

  @@unique([gstin, company_name])
}

model Address {
  id            Int     @id @default(autoincrement())
  gstin         String
  addressType   String
  type          String
  contactName   String
  line1         String
  line2         String?
  city          String
  pincode       String
  stateCode     String
  stateName     String
  email         String?
  phone         String
  company_name  String
  deliveryGstin String?
  company       Company @relation(fields: [gstin, company_name], references: [gstin, company_name])

  @@index([gstin, company_name])
}

model SalesAddress {
  id            Int          @id @default(autoincrement())
  gstin         String
  addressType   String
  type          String
  contactName   String
  line1         String
  line2         String?
  city          String
  pincode       String
  stateCode     String
  stateName     String
  email         String?
  phone         String
  company_name  String
  deliveryGstin String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime?    @updatedAt
  billOrders    SalesOrder[] @relation("BillToSalesAddress")
  shipOrders    SalesOrder[] @relation("ShipToSalesAddress")

  @@index([gstin, company_name])
}

model SalesOrder {
  id                 Int                       @id @default(autoincrement())
  orderNo            String                    @unique
  orderDate          DateTime                  @default(now())
  orderDateIST       DateTime?                 @db.Date
  gstin              String
  status             Int                       @default(0)
  company_name       String
  totalPrice         Float
  billToAddressId    Int?
  shipToAddressId    Int?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime?                 @updatedAt
  type_name          String                    @db.VarChar(100)
  type               String                    @db.VarChar(100)
  numberItem         Int
  seller             String                    @db.VarChar(100)
  transportType      String                    @db.VarChar(100)
  saleman            String                    @db.VarChar(100)
  revision           Int                       @default(0)
  company_billing    Int                       @default(0)
  pdf_url            String?                   @db.VarChar(255)
  round_amount       Decimal?                  @default(0.00) @db.Decimal(10, 2)
  incoterm           String?                   @db.VarChar(255)
  hub                String?
  mode_of_booking    String?
  warehouse          String?
  vehicleNo          String?                   @db.VarChar(100)
  orderNoOld         String?
  qu_ai_date         DateTime?
  qu_ai_percent      Float?
  billToSalesAddrId  Int?
  shipToSalesAddrId  Int?
  stick1_url         String?                   @db.VarChar(255)
  DateOK             DateTime?
  totalNoGst         Decimal?                  @default(0.00) @db.Decimal(10, 2)
  orderDetails       OrderDetails[]
  billToSalesAddress SalesAddress?             @relation("BillToSalesAddress", fields: [billToSalesAddrId], references: [id], onDelete: Restrict)
  company            Company                   @relation(fields: [gstin, company_name], references: [gstin, company_name])
  shipToSalesAddress SalesAddress?             @relation("ShipToSalesAddress", fields: [shipToSalesAddrId], references: [id], onDelete: Restrict)
  changeLogs         SalesOrderChangeLog[]
  history            SalesOrderStatusHistory[]
  payments           SalesPayment[]

  @@index([warehouse])
  @@index([billToSalesAddrId], map: "SalesOrder_billToSalesAddrId_fkey")
  @@index([gstin, company_name], map: "SalesOrder_gstin_company_name_fkey")
  @@index([shipToSalesAddrId], map: "SalesOrder_shipToSalesAddrId_fkey")
  @@index([company_name, type, orderDate, saleman, totalPrice], map: "idx_sales_report_optimized")
}

model SalesPayment {
  id            Int           @id @default(autoincrement())
  orderNo       String
  amountPaid    Decimal       @db.Decimal(12, 2)
  image_url     String?
  paymentStatus PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  approvedBy    String?       @db.VarChar(20)
  paymentType   PaymentType   @default(SCREENSHOT)
  salesOrder    SalesOrder    @relation(fields: [orderNo], references: [orderNo], onDelete: Cascade, onUpdate: Cascade)

  @@index([orderNo], map: "SalesPayment_orderNo_fkey")
}

model OrderDetails {
  id            Int        @id @default(autoincrement())
  orderId       String
  mnId          String
  quantity      Int
  rateUnit      Float
  unit          String
  taxableAmount Float
  taxedAmount   Float
  igst          Float
  igstAmount    Float
  cgst          Float
  cgstAmount    Float
  sgst          Float
  sgstAmount    Float
  product       Product    @relation(fields: [mnId], references: [mn])
  salesOrder    SalesOrder @relation(fields: [orderId], references: [orderNo], onDelete: Cascade, onUpdate: Cascade)

  @@index([mnId])
  @@index([orderId], map: "OrderDetails_orderId_fkey")
  @@index([orderId])
}

model Product {
  id            Int                    @id @default(autoincrement())
  brand         String                 @default("")
  mn            String                 @unique
  type          String?                @default("")
  power         Decimal?               @default(0.000000000000000000000000000000)
  description   String
  active        Boolean                @default(false)
  brand_short   String                 @default("")
  desc_offcial  String                 @default("")
  group         Int?                   @default(0)
  igst          Decimal                @default(0.000000000000000000000000000000)
  mn_pn         String                 @default("")
  pn            String?                @default("")
  family        String                 @default("")
  company_name  String
  hsn           String
  initial_stock Int                    @default(100)
  unit_price    String?
  warranty      Int?

  transferItems TransferItem[]   
  transactions  InventoryTransaction[]
  orderDetails  OrderDetails[]
  productPrice  ProductPrice?
  inventory     WarehouseInventory[]
  purchaseOrderItems PurchaseOrderItem[]
}

model ProductPrice {
  mn      String  @id
  mrp     Decimal @db.Decimal(10, 2)
  price1  Decimal @db.Decimal(10, 2)
  price2  Decimal @db.Decimal(10, 2)
  product Product @relation(fields: [mn], references: [mn], onDelete: Cascade, map: "fk_ProductPrice_Product")
}

model Warehouse {
  id           Int                    @id @default(autoincrement())
  name         String
  location     String
  transactions InventoryTransaction[]
  warehouses   UserWarehouse[]
  inventory    WarehouseInventory[]

  transfersFrom TransferOrder[] @relation("FromWarehouse")
  transfersTo   TransferOrder[] @relation("ToWarehouse")
  purchaseOrders PurchaseOrder[]
}

model WarehouseInventory {
  id          Int       @id @default(autoincrement())
  warehouseId Int
  productMn   String
  physicalQty Int
  reservedQty Int
  minimumQty  Int       @default(0)
  product     Product   @relation(fields: [productMn], references: [mn])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, productMn])
  @@index([productMn], map: "WarehouseInventory_productMn_fkey")
}

model InventoryTransaction {
  id             Int              @id @default(autoincrement())
  warehouseId    Int
  warehouseName  String
  productMn      String
  qtyChange      Int
  type           InventoryTxnType
  reference      String?
  createdAt      DateTime         @default(now())
  createdBy      String?
  physicalAfter  Int
  physicalBefore Int
  reservedAfter  Int
  reservedBefore Int
  user           User?            @relation(fields: [createdBy], references: [trigram])
  product        Product          @relation(fields: [productMn], references: [mn])
  warehouse      Warehouse        @relation(fields: [warehouseId], references: [id])

  @@index([warehouseId])
  @@index([productMn])
  @@index([createdBy])
  @@index([warehouseId, productMn])
}

model TransferOrder {
  id              Int      @id @default(autoincrement())
  transferNo      String   @unique

  fromWarehouseId Int
  toWarehouseId   Int
  fromWarehouseName String?
  toWarehouseName String?
  
  status          TransferStatus @default(CREATED)
  createdBy       String?

  dispatchedAt DateTime?
  receivedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User?     @relation(fields: [createdBy], references: [trigram])
  fromWarehouse   Warehouse @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  items           TransferItem[]

  @@index([status])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
}

model TransferItem {
  id          Int    @id @default(autoincrement())
  transferId  Int
  transferNo  String
  productMn   String

  requestedQty Int
  dispatchedQty Int @default(0)
  receivedQty Int     @default(0)

  transfer    TransferOrder @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productMn], references: [mn])

  @@index([transferId])
  @@unique([transferId, productMn])
  @@unique([transferNo, productMn])
}

model PurchaseOrder {
  id Int @id @default(autoincrement())
  poNumber           String @unique
  warehouseId        Int
  warehouseName String
  supplierId         Int
  supplierName      String
  status             PurchaseStatusType @default(CREATED)

  orderDate       DateTime @default(now())
  expectedDate       DateTime

  createdBy   String
  // receivedBy
  remarks            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  createdByUser User? @relation(fields: [createdBy], references: [trigram])

  items PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id Int @id @default(autoincrement())
  purchaseOrderId Int
  productMn String

  orderedQty Int
  receivedQty Int @default(0)        // Important for partial receive

  createdAt DateTime @default(now())
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product Product @relation(fields: [productMn], references: [mn])
  @@index([productMn])
  @@unique([purchaseOrderId,productMn])
}


model Supplier {
  id Int @id @default(autoincrement())
  name String
  contactPerson     String?
  phone             String?
  email             String?

  address           String?
  city              String?
  state             String?
  country           String?

  gstNumber         String?

  deletedAt   DateTime?  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  @@index([deletedAt])
}



model Salesman {
  id        Int      @id @default(autoincrement())
  trigram   String   @unique
  company   String
  location  String?
  pwd       String
  rule      Int
  createdAt DateTime @default(now())
  region    String?
}

model User {
  id           Int                    @id @default(autoincrement())
  trigram      String                 @unique
  company      String
  location     String?
  pwd          String
  roleId       Int
  region       String?
  transactions InventoryTransaction[]
  role         Role                   @relation(fields: [roleId], references: [id])
  warehouses   UserWarehouse[]
  transferOrders TransferOrder[]
  purchaseOrders PurchaseOrder[]

  @@index([roleId], map: "User_roleId_fkey")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  homepage    String?          @default("DOCS") @db.VarChar(100)
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id     Int              @id @default(autoincrement())
  action String           @unique
  roles  RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
  @@index([permissionId], map: "RolePermission_permissionId_fkey")
}

model UserWarehouse {
  userId      Int
  warehouseId Int
  accessType  WarehouseAccessType @default(VIEW)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse   Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([userId, warehouseId])
  @@index([warehouseId], map: "UserWarehouse_warehouseId_fkey")
}

model State {
  code     String @id
  name     String
  nameCode String @db.VarChar(100)
}

model SalesOrderStatusHistory {
  id                     Int        @id @default(autoincrement())
  orderNo                String
  status                 Int
  modified_at            DateTime   @default(now())
  transition             String
  duration_from_start    String
  duration_from_previous String
  salesOrder             SalesOrder @relation(fields: [orderNo], references: [orderNo], onDelete: Cascade, onUpdate: Cascade)

  @@index([orderNo], map: "SalesOrderStatusHistory_orderNo_fkey")
  @@map("SalesOrderStatusHistory")
}

model Gchat_WebHooks {
  id      Int    @id @default(autoincrement())
  sss     String @default("bop") @db.VarChar(50)
  ttt     String @unique @db.VarChar(50)
  webhook String @db.Text
}

model Gchat_Template {
  id_GT       String           @id @unique
  vcard       Boolean
  title       String
  subtitle    String?
  message     String?
  buttons     Json?
  createdAt   DateTime         @default(now())
  list_item   Boolean          @default(false)
  url_picture String?          @db.VarChar(255)
  issueTos    Gchat_Issue_To[]
}

model Gchat_Issue_To {
  id         Int            @id @default(autoincrement())
  company    String
  service    String         @default("bop")
  statusTo   Int
  statusFrom Int?
  sence      Int
  id_GT      String
  to_webhook String
  vite       Boolean        @default(true)
  eventType  EventType       @default(status_change)
  template   Gchat_Template @relation(fields: [id_GT], references: [id_GT])
  logs       Gchat_Log[]

  @@index([id_GT], map: "Gchat_Issue_To_id_GT_fkey")
}

model Gchat_Log {
  id_Log    Int            @id @default(autoincrement())
  messageId String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  issueToId Int
  status_to Int
  buttons   Json?
  message   String?
  subtitle  String?
  title     String?
  issueTo   Gchat_Issue_To @relation(fields: [issueToId], references: [id])

  @@index([issueToId], map: "Gchat_Log_issueToId_fkey")
}

model SalesOrderChangeLog {
  id           Int        @id @default(autoincrement())
  orderNo      String
  revision     Int
  changedField String     @db.VarChar(100)
  oldValue     String?    @db.Text
  newValue     String?    @db.Text
  changedAt    DateTime   @default(now())
  salesOrder   SalesOrder @relation(fields: [orderNo], references: [orderNo], onDelete: Cascade, onUpdate: Cascade)

  @@index([orderNo], map: "SalesOrderChangeLog_orderNo_fkey")
}

model SalesTargets {
  id         Int      @id @default(autoincrement())
  trigram    String   @db.Char(3)
  month_date DateTime @db.Date
  target_inr BigInt

  @@unique([trigram, month_date], map: "uq_trigram_month")
}

model projects {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  progress  Float    @db.Float
  startDate DateTime @db.Date
  status    String   @db.VarChar(50)
}

enum PaymentStatus {
  PENDING
  APPROVED
}

enum EventType {
  status_change
  payment_uploaded
  payment_approved
}

enum PaymentType {
  SCREENSHOT
  ADJUSTMENT
  FINANCE
}

enum WarehouseAccessType {
  VIEW
  MANAGE
}

enum InventoryTxnType {
  INWARD
  OUTWARD
  RESERVE
  RELEASE
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  LOSS
}

enum TransferStatus {
  CREATED
  DISPATCHED
  IN_TRANSIT
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
}

enum PurchaseStatusType {
  CREATED 
  CANCELLED
  PARTIALLY_RECEIVED
  COMPLETED
}